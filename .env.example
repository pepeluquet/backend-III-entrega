# Copia este archivo a .env y completa los valores (no subas .env a Git).
# cp .env.example .env   (Linux/macOS)  |  copy .env.example .env   (Windows)

PORT=8080
NODE_ENV=development

# --- MongoDB local (mongod en tu PC) ---
# MONGO_URL=mongodb://localhost:27017/backend-iii-adopciones?retryWrites=true&w=majority

# --- MongoDB Atlas (nube) — reemplaza usuario, contraseña y cluster ---
# Formato SRV (Drivers → Node en Atlas):
# MONGO_URL=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/backend-iii-adopciones?retryWrites=true&w=majority

# Valor por defecto si no defines MONGO_URL (src/app.js):
# mongodb://localhost:27017/backend-iii-adopciones?retryWrites=true&w=majority
